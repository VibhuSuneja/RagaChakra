# MongoDB connection string
# Local:  mongodb://localhost:27017/ragachakra
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/ragachakra
MONGO_URI=mongodb://localhost:27017/ragachakra

# Express server port
PORT=5000

# Session secret (change before deploying)
SESSION_SECRET=ragachakra-dev-secret-change-me

# Feature flag: set to "true" to enable Vedic astrology re-rank layer
# Leave "false" for MVP
ASTRO_ENABLED=false
