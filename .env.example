# ==========================================
# RagaChakra - Production Environment Variables
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
# NOTE: For deployment (like Render), replace the localhost URI with your MongoDB Atlas URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ragachakra?retryWrites=true&w=majority

# CORS & Client Configuration
# If the frontend is served by the backend, this can often be left as your production URL
CLIENT_ORIGIN=https://your-production-url.onrender.com

# Feature Flags
# Set to 'true' to enable Vedic astrology reranking features
ASTRO_ENABLED=false
